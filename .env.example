# Smart Travel Planner - Environment Variables Configuration Template

# 1. Server Configuration
PORT=5000
NODE_ENV=development

# 2. Database Configuration
# - For local development, leave this empty to automatically spin up a zero-config in-memory MongoDB.
# - For persistent development or production, provide a valid connection string:
MONGODB_URI=mongodb://localhost:27017/smart-travel-planner

# 3. Security & CORS Configuration
JWT_SECRET=supersecretjwttokenkey
JWT_ACCESS_SECRET=supersecretjwtaccesskey12345
JWT_REFRESH_SECRET=supersecretjwtrefreshkey12345
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 4. Live API Integrations
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_KEY
GEOAPIFY_API_KEY=YOUR_GEOAPIFY_KEY
MAP_API_KEY=YOUR_MAP_KEY
GROQ_API_KEY=YOUR_GROQ_KEY
