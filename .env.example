# Smart Travel Planner - Environment Variables Configuration Template

# 1. Server Configuration
PORT=5000
NODE_ENV=development

# 2. Database Configuration
# - For local development, leave this empty to automatically spin up a zero-config in-memory MongoDB.
# - For persistent development or production, provide a valid connection string:
#   Local DB: mongodb://localhost:27017/smart-travel-planner
#   Cloud Atlas: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/smart-travel-planner?retryWrites=true&w=majority
MONGODB_URI=

# 3. Security & CORS Configuration
# - Secret key used for signing JWT access tokens (change to a strong random string in production)
JWT_SECRET=supersecretjwttokenkey

# - Comma-separated list of allowed browser origins for API access (CORS whitelist)
# - Omit or leave empty in development to fallback to http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 4. Optional Integration Features
# - OpenAI / Gemini API keys if you configure advanced AI features
# GEMINI_API_KEY=your_gemini_api_key_here
